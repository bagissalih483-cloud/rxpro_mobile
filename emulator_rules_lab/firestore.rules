// FIX Firestore Rules Draft - 51A-I
// DO NOT DEPLOY DIRECTLY.
// This file is documentation/staging draft only.
// This draft repairs the 51A-H static findings in docs only.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isPlatformAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          userDoc(request.auth.uid).data.role == "admin"
          || userDoc(request.auth.uid).data.activeRole == "admin"
          || userDoc(request.auth.uid).data.accountKind == "admin"
          || userDoc(request.auth.uid).data.isAdmin == true
          || userDoc(request.auth.uid).data.platformAdmin == true
        );
    }

    function hasBusinessId(data) {
      return data.businessId is string && data.businessId.size() > 0;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function businessDoc(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId));
    }

    function isBusinessOwnerByBusinessDoc(businessId) {
      return signedIn() && exists(/databases/$(database)/documents/businesses/$(businessId)) && (
        businessDoc(businessId).data.ownerUid == request.auth.uid ||
        businessDoc(businessId).data.ownerId == request.auth.uid ||
        businessDoc(businessId).data.businessOwnerUid == request.auth.uid ||
        businessDoc(businessId).data.userId == request.auth.uid ||
        businessDoc(businessId).data.uid == request.auth.uid ||
        businessDoc(businessId).data.createdBy == request.auth.uid ||
        businessDoc(businessId).data.adminUid == request.auth.uid ||
        businessDoc(businessId).data.managerUid == request.auth.uid
      );
    }

    function isBusinessOwnerByUserDoc(businessId) {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        userDoc(request.auth.uid).data.businessId == businessId ||
        userDoc(request.auth.uid).data.ownedBusinessId == businessId ||
        userDoc(request.auth.uid).data.activeBusinessId == businessId ||
        userDoc(request.auth.uid).data.selectedBusinessId == businessId
      );
    }

    function isBusinessOwner(businessId) {
      return isBusinessOwnerByBusinessDoc(businessId) || isBusinessOwnerByUserDoc(businessId);
    }

    function isBusinessMemberByUserDoc(businessId) {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        userDoc(request.auth.uid).data.activeBusinessId == businessId ||
        userDoc(request.auth.uid).data.staffBusinessId == businessId ||
        userDoc(request.auth.uid).data.businessId == businessId
      );
    }

    function isBusinessMember(businessId) {
      return isBusinessOwner(businessId) || isBusinessMemberByUserDoc(businessId);
    }

    function notificationRecipient(data) {
      return signedIn() && (
        (data.targetScope == 'user' && data.recipientUid == request.auth.uid) ||
        (data.targetScope == 'business' && data.businessId is string && isBusinessMember(data.businessId))
      );
    }

    function validNotificationPreferences(uid) {
      return request.resource.data.keys().hasOnly([
          "uid",
          "pushEnabled",
          "appointmentReminders",
          "messages",
          "campaigns",
          "system",
          "updatedAt",
          "updatedAtIso"
        ])
        && request.resource.data.keys().hasAll([
          "uid",
          "pushEnabled",
          "appointmentReminders",
          "messages",
          "campaigns",
          "system"
        ])
        && request.resource.data.uid == uid
        && request.resource.data.pushEnabled is bool
        && request.resource.data.appointmentReminders is bool
        && request.resource.data.messages is bool
        && request.resource.data.campaigns is bool
        && request.resource.data.system is bool;
    }

    function publicDocumentForbiddenFields() {
      return [
        "ownerEmail",
        "customerEmail",
        "ownerPhone",
        "customerPhone",
        "privatePhone",
        "personalPhone",
        "customerUid",
        "customerUids",
        "customerIds",
        "customers",
        "customerList",
        "clientUid",
        "clientUids",
        "balance",
        "walletBalance",
        "revenue",
        "totalRevenue",
        "expense",
        "expenses",
        "profit",
        "iban",
        "taxNumber",
        "identityNumber",
        "tcKimlikNo",
        "notes",
        "internalNotes",
        "privateNotes"
      ];
    }

    function protectedUserFields() {
      return [
        "role",
        "roles",
        "activeRole",
        "accountKind",
        "isAdmin",
        "platformAdmin",
        "admin",
        "permissions",
        "claims"
      ];
    }

    function protectedBusinessOwnershipFields() {
      return [
        "ownerUid",
        "ownerId",
        "businessOwnerUid",
        "userId",
        "uid",
        "createdBy",
        "createdByUid",
        "adminUid",
        "managerUid"
      ];
    }

    function hasNoPublicPrivateFields(data) {
      return !data.keys().hasAny(publicDocumentForbiddenFields());
    }

    function keepsFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function messageParticipant(data) {
      return signedIn() && (
        data.customerUid == request.auth.uid ||
        data.senderUid == request.auth.uid ||
        data.recipientUid == request.auth.uid ||
        (data.businessId is string && isBusinessMember(data.businessId))
      );
    }

    function threadParticipant(threadId) {
      return signedIn() && exists(/databases/$(database)/documents/messageThreads/$(threadId)) &&
        messageParticipant(get(/databases/$(database)/documents/messageThreads/$(threadId)).data);
    }

    function createsOwnBusiness(data) {
      return signedIn() && (
        data.ownerUid == request.auth.uid ||
        data.ownerId == request.auth.uid ||
        data.businessOwnerUid == request.auth.uid ||
        data.userId == request.auth.uid ||
        data.uid == request.auth.uid ||
        data.createdBy == request.auth.uid ||
        data.adminUid == request.auth.uid ||
        data.managerUid == request.auth.uid
      );
    }

    match /users/{uid} {
      allow read, create: if isSelf(uid);
      allow update: if (
          isSelf(uid)
          && keepsFieldsUnchanged(protectedUserFields())
        )
        || isPlatformAdmin();
      allow delete: if false;

      match /fcmTokens/{tokenId} {
        allow read, create, update, delete: if isSelf(uid);
      }
    }

    match /publicProfiles/{uid} {
      allow read: if true;
      allow create: if isSelf(uid)
        && hasNoPublicPrivateFields(request.resource.data);
      allow update: if isSelf(uid)
        && hasNoPublicPrivateFields(request.resource.data)
        && keepsFieldsUnchanged(["uid"]);
      allow delete: if false;
    }

    match /accountDeletionRequests/{uid} {
      allow read, create, update: if isSelf(uid) && request.resource.data.uid == uid;
      allow delete: if false;
    }

    match /functionRateLimits/{docId} {
      allow read, write: if false;
    }

    match /functionAbuseLogs/{docId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read, create: if isPlatformAdmin();
      allow update, delete: if false;
    }

    match /moderationBlocks/{blockId} {
      allow read, create, update: if isPlatformAdmin();
      allow delete: if false;
    }

    match /businessProfilePostReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.postId.size() > 0
        && request.resource.data.reason is string
        && request.resource.data.status == "open";
      allow read: if resource.data.uid == request.auth.uid || isPlatformAdmin();
      allow update: if isPlatformAdmin()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.postId == resource.data.postId;
      allow delete: if false;
    }

    match /businessReviewReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.reviewId is string
        && request.resource.data.reviewId.size() > 0
        && request.resource.data.businessId is string
        && request.resource.data.businessId.size() > 0
        && request.resource.data.reason is string
        && request.resource.data.status == "open";
      allow read: if resource.data.uid == request.auth.uid || isPlatformAdmin();
      allow update: if isPlatformAdmin()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.reviewId == resource.data.reviewId;
      allow delete: if false;
    }

    match /campaignReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.campaignId is string
        && request.resource.data.campaignId.size() > 0
        && request.resource.data.sourceCollection in ["businessCampaigns", "campaigns"]
        && request.resource.data.businessId is string
        && request.resource.data.reason is string
        && request.resource.data.status == "open";
      allow read: if resource.data.uid == request.auth.uid || isPlatformAdmin();
      allow update: if isPlatformAdmin()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.campaignId == resource.data.campaignId
        && request.resource.data.sourceCollection == resource.data.sourceCollection;
      allow delete: if false;
    }

    match /businessCampaigns/{campaignId} {
      allow read: if true;
      allow create: if signedIn()
        && hasBusinessId(request.resource.data)
        && hasNoPublicPrivateFields(request.resource.data)
        && (
          request.resource.data.uid == request.auth.uid ||
          isBusinessMember(request.resource.data.businessId)
        );
      allow update: if isPlatformAdmin() || (
        signedIn() &&
        hasBusinessId(resource.data) &&
        hasBusinessId(request.resource.data) &&
        isBusinessMember(resource.data.businessId) &&
        isBusinessMember(request.resource.data.businessId) &&
        hasNoPublicPrivateFields(request.resource.data) &&
        keepsFieldsUnchanged(["businessId", "uid", "ownerUid", "createdByUid"])
      );
      allow delete: if false;
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if signedIn()
        && hasBusinessId(request.resource.data)
        && hasNoPublicPrivateFields(request.resource.data)
        && (
          request.resource.data.uid == request.auth.uid ||
          isBusinessMember(request.resource.data.businessId)
        );
      allow update: if isPlatformAdmin() || (
        signedIn() &&
        hasBusinessId(resource.data) &&
        hasBusinessId(request.resource.data) &&
        isBusinessMember(resource.data.businessId) &&
        isBusinessMember(request.resource.data.businessId) &&
        hasNoPublicPrivateFields(request.resource.data) &&
        keepsFieldsUnchanged(["businessId", "uid", "ownerUid", "createdByUid"])
      );
      allow delete: if false;
    }

    match /businessReviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isPlatformAdmin();
      allow delete: if false;
    }

    match /businesses/{businessId} {
      allow read: if true;
      allow create: if createsOwnBusiness(request.resource.data)
        && hasNoPublicPrivateFields(request.resource.data);
      allow update: if isBusinessOwner(businessId)
        && hasNoPublicPrivateFields(request.resource.data)
        && keepsFieldsUnchanged(protectedBusinessOwnershipFields());
      allow delete: if false;
    }

    match /directory_pois_google_cache/{placeId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /businessClaimRequests/{claimId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.placeId is string
        && request.resource.data.placeId.size() > 0
        && request.resource.data.status == "pending";
      allow read: if resource.data.uid == request.auth.uid || isPlatformAdmin();
      allow update: if isPlatformAdmin()
        || (
          resource.data.uid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && resource.data.status == "pending"
          && request.resource.data.status == "pending"
        );
      allow delete: if false;
    }

    match /businessStaff/{staffId} {
      allow read: if signedIn() && (isBusinessOwner(resource.data.businessId) || resource.data.linkedUid == request.auth.uid || isBusinessMember(resource.data.businessId));
      allow create: if signedIn() && hasBusinessId(request.resource.data) && isBusinessOwner(request.resource.data.businessId);
      allow update: if signedIn() && hasBusinessId(resource.data) && (isBusinessOwner(resource.data.businessId) || resource.data.linkedUid == request.auth.uid);
      allow delete: if false;
    }

    match /businessServices/{serviceId} {
      allow read: if true;
      allow create: if signedIn() && hasBusinessId(request.resource.data) && isBusinessOwner(request.resource.data.businessId);
      allow update: if signedIn() && hasBusinessId(resource.data) && isBusinessOwner(resource.data.businessId);
      allow delete: if false;
    }

    match /appointments/{appointmentId} {
      allow read: if signedIn() && (resource.data.customerUid == request.auth.uid || isBusinessMember(resource.data.businessId));
      allow create: if signedIn() && hasBusinessId(request.resource.data) && (request.resource.data.customerUid == request.auth.uid || isBusinessMember(request.resource.data.businessId));
      allow update: if signedIn() && hasBusinessId(resource.data) && (resource.data.customerUid == request.auth.uid || isBusinessMember(resource.data.businessId));
      allow delete: if false;
    }

    match /appointmentSlots/{slotId} {
      allow read: if signedIn() && (
        resource.data.customerUid == request.auth.uid ||
        isBusinessMember(resource.data.businessId)
      );
      allow create: if signedIn() && hasBusinessId(request.resource.data) && (
        request.resource.data.customerUid == request.auth.uid ||
        isBusinessMember(request.resource.data.businessId)
      );
      allow update: if signedIn() && hasBusinessId(resource.data) && (
        resource.data.customerUid == request.auth.uid ||
        isBusinessMember(resource.data.businessId)
      );
      allow delete: if false;
    }

    match /businessCustomers/{customerId} {
      allow read: if signedIn() && hasBusinessId(resource.data) && isBusinessMember(resource.data.businessId);
      allow create: if signedIn() && hasBusinessId(request.resource.data) && isBusinessMember(request.resource.data.businessId);
      allow update: if signedIn() && hasBusinessId(resource.data) && hasBusinessId(request.resource.data) && isBusinessMember(resource.data.businessId) && isBusinessMember(request.resource.data.businessId);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if notificationRecipient(resource.data);
      allow create: if notificationRecipient(request.resource.data);
      allow update: if notificationRecipient(resource.data);
      allow delete: if false;
    }

    match /notificationPreferences/{uid} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid)
        && validNotificationPreferences(uid);
      allow delete: if false;
    }

    match /messageThreads/{threadId} {
      allow read: if messageParticipant(resource.data);
      allow create: if messageParticipant(request.resource.data);
      allow update: if messageParticipant(resource.data);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if threadParticipant(threadId);
        allow create: if threadParticipant(threadId);
        allow update: if threadParticipant(threadId);
        allow delete: if false;
      }
    }

    match /businessExpenses/{expenseId} {
      allow read: if signedIn() && hasBusinessId(resource.data) && isBusinessMember(resource.data.businessId);
      allow create: if signedIn() && hasBusinessId(request.resource.data) && isBusinessMember(request.resource.data.businessId);
      allow update: if signedIn() && hasBusinessId(resource.data) && isBusinessMember(resource.data.businessId);
      allow delete: if false;
    }

    match /businessActivityLogs/{logId} {
      allow read: if signedIn() && hasBusinessId(resource.data) && isBusinessMember(resource.data.businessId);
      allow create: if signedIn() && hasBusinessId(request.resource.data) && isBusinessMember(request.resource.data.businessId);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
