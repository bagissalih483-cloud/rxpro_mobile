{
  "name": "rxpro-rules-tests",
  "private": true,
  "scripts": {
    "test:firestore": "firebase emulators:exec --only firestore \"mocha --timeout 30000 tests/firestore.rules.test.js\"",
    "test:storage": "firebase emulators:exec --only firestore,storage \"mocha --timeout 30000 tests/storage.rules.test.js\"",
    "test:rules": "firebase emulators:exec --only firestore,storage \"mocha --timeout 30000 tests/*.rules.test.js\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "firebase": "^10.14.1",
    "firebase-tools": "^14.0.0",
    "mocha": "^10.8.2"
  }
}
